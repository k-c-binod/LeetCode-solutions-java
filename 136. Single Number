class Solution {
    public int singleNumber(int[] nums) {
        Arrays.sort(nums);
        if(nums.length == 1) {
            return nums[0];
        }
        try{
            for(int i=0;i<nums.length;i= i+2) {
            if(nums[i] != nums[i+1]) {
                return nums[i];
            }
        }
        } catch(Exception e){
            return nums[nums.length-1];
        }
            return 0;
        }
        
        
        
    }