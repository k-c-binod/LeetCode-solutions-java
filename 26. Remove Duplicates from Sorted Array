class Solution {
    public int removeDuplicates(int[] nums) {
        Set<Integer> lst = new LinkedHashSet<Integer>();
        for(int i =0;i<nums.length;i++) {
            lst.add(nums[i]);
        }
        int k = 0;
        for(int x : lst) {
            nums[k] = x;
            k++;
        }
        return lst.size();
        
        
    }
}