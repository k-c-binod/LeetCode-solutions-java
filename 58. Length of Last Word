class Solution {
    public int lengthOfLastWord(String s) {
        s = s.trim();
        int n = s.length();
        
        for(int i=n-1; i>=0; i--) {
            char str = s.charAt(i);
            char space = ' ';
            if(str == space) {
                return n-1-i;
            }         
        }
        return n;
    }
}