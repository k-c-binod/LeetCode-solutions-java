class Solution {
    public int[] sortedSquares(int[] nums) {
        List<Integer> lst = new ArrayList<Integer>();
        for(int i=0;i<nums.length;i++) {
            int no = nums[i]*nums[i];
            lst.add(no);
        }
        Collections.sort(lst);

        return lst.stream().mapToInt(i->i).toArray();
    }
}