class Solution {
    public String reverseVowels(String s) {
       String vow = "aeiouAEIOU";
       char[] arr = s.toCharArray();
       

       int i=0,j=s.length()-1;
       while(i<j) {
        while(i<j &&!vow.contains(arr[i]+"")) {
            i++;
        }
        while(i<j && !vow.contains(arr[j]+"")){
            j--;
        }
        char temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
        i++;
        j--;
        
       }
       

       return new String(arr);
    }
}